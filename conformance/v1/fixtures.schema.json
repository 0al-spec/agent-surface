        "application_claims_runtime_observation",
        "approval_hash_substitution",
        "claimed_issuer_mismatched_grant",
        "different_execution_hash",
        "different_input_hash",
        "different_input_schema_hash",
        "exact_revocation_replay",
        "fabricated_receipt",
        "incomplete_references",
        "passport_status_unavailable",
        "policy_denied",
        "proof_session_binding_mismatch",
        "proposal_only_state_change",
        "raw_credential",
        "raw_credential_release",
        "receipt_claims_authority",
        "receipt_hash_mutated",
        "revocation_state_unknown",
        "revoked_grant",
        "runtime_attestation_unavailable",
        "runtime_claims_application_effect",
        "runtime_identity_mismatch",
        "sender_credential_wrong_audience",
        "stale_capability_match",
        "stale_surface",
        "stronger_action_substitution",
        "training_policy_wider",
        "unclosed_companion_set",
        "non_fixed_point_input",
        "unknown_outcome_new_key",
        "unknown_outcome_retry",
        "unknown_remote_path",
        "valid",
        "valid_application_receipt",
        "valid_runtime_receipt",
        "version_hash_reuse",
        "widened_action_set",
        "wider_returned_grant"
      ]
