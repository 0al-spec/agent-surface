{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0al-spec/agent-surface/conformance/schemas/fixtures/v1",
  "title": "ASP Canonical Semantic Fixtures v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "suite_id",
    "suite_version",
    "fixture_catalog_id",
    "fixtures",
    "mutations"
  ],
  "properties": {
    "$schema": {
      "const": "./fixtures.schema.json"
    },
    "schema_version": {
      "const": 1
    },
    "suite_id": {
      "const": "https://github.com/0al-spec/agent-surface/conformance/suite/v1"
    },
    "suite_version": {
      "const": "1.0.0"
    },
    "fixture_catalog_id": {
      "const": "agent-surface/conformance/fixtures/v1"
    },
    "fixtures": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/fixture"
      },
      "allOf": [
        { "$ref": "#/$defs/fixtureCoverage" }
      ]
    },
    "mutations": {
      "type": "array",
      "minItems": 38,
      "maxItems": 38,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/mutation"
      },
      "allOf": [
        { "$ref": "#/$defs/mutationCoverage" }
      ]
    }
  },
  "$defs": {
    "fixtureId": {
      "enum": [
        "ASP-F-SP-001",
        "ASP-F-GI-001",
        "ASP-F-GI-006",
        "ASP-F-GI-007",
        "ASP-F-AE-001",
        "ASP-F-AE-002",
        "ASP-F-RP-001",
        "ASP-F-RP-002",
        "ASP-F-RM-001",
        "ASP-F-AA-001"
      ]
