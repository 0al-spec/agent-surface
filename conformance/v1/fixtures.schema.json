        "ASP-M-DIFFERENT-INPUT-SCHEMA-HASH",
        "ASP-M-EXACT-REVOCATION-REPLAY",
        "ASP-M-FABRICATED-RECEIPT",
        "ASP-M-INCOMPLETE-REFERENCES",
        "ASP-M-PASSPORT-STATUS-UNAVAILABLE",
        "ASP-M-POLICY-DENIED",
        "ASP-M-PROOF-SESSION-BINDING-MISMATCH",
        "ASP-M-PROPOSAL-ONLY-STATE-CHANGE",
        "ASP-M-RAW-CREDENTIAL",
        "ASP-M-RAW-CREDENTIAL-RELEASE",
        "ASP-M-RECEIPT-CLAIMS-AUTHORITY",
        "ASP-M-RECEIPT-HASH-MUTATED",
        "ASP-M-REVOCATION-STATE-UNKNOWN",
        "ASP-M-REVOKED-GRANT",
        "ASP-M-RUNTIME-ATTESTATION-UNAVAILABLE",
        "ASP-M-RUNTIME-CLAIMS-APPLICATION-EFFECT",
        "ASP-M-RUNTIME-IDENTITY-MISMATCH",
        "ASP-M-SENDER-CREDENTIAL-WRONG-AUDIENCE",
        "ASP-M-STALE-CAPABILITY-MATCH",
        "ASP-M-STALE-SURFACE",
        "ASP-M-STRONGER-ACTION-SUBSTITUTION",
        "ASP-M-TRAINING-POLICY-WIDER",
        "ASP-M-UNCLOSED-COMPANION-SET",
