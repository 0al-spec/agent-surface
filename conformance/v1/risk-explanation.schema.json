{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0al-spec/agent-surface/conformance/schemas/risk-explanation/v1",
  "title": "ASP Risk Explanation UI Hint v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "default_language",
    "localizations"
  ],
  "properties": {
    "default_language": {
      "$ref": "#/$defs/language"
    },
    "localizations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "$ref": "#/$defs/localization"
      }
    }
  },
  "$defs": {
    "language": {
      "type": "string",
      "minLength": 1,
      "maxLength": 63,
      "pattern": "^[a-z]{2,8}(?:-[a-z]{4})?(?:-(?:[a-z]{2}|[0-9]{3}))?(?:-(?:[a-z0-9]{5,8}|[0-9][a-z0-9]{3}))*(?![\\s\\S])"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[^\\u0000-\\u001F\\u007F-\\u009F\\u061C\\u200E\\u200F\\u202A-\\u202E\\u2066-\\u2069]+(?![\\s\\S])"
    },
    "effectSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effect_id",
        "summary"
      ],
      "properties": {
        "effect_id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "$ref": "#/$defs/summary"
        }
      }
    },
    "localization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "summary",
        "effect_summaries"
      ],
      "properties": {
        "language": {
          "$ref": "#/$defs/language"
        },
        "summary": {
          "$ref": "#/$defs/summary"
        },
        "effect_summaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effectSummary"
          }
        }
      }
    }
  }
}
