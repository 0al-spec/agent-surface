{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0al-spec/agent-surface/conformance/schemas/bundles/v1",
  "title": "ASP Adoption-Oriented Conformance Bundle Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "registry_id",
    "registry_version",
    "suite_id",
    "suite_version",
    "protocol_version",
    "claim_effect",
    "bundles"
  ],
  "properties": {
    "$schema": { "const": "./bundles.schema.json" },
    "schema_version": { "const": 1 },
    "registry_id": {
      "const": "https://github.com/0al-spec/agent-surface/conformance/bundles/v1"
    },
    "registry_version": { "const": "1.0.0" },
    "suite_id": {
      "const": "https://github.com/0al-spec/agent-surface/conformance/suite/v1"
    },
    "suite_version": { "const": "1.8.0" },
    "protocol_version": { "const": "agent-surface/0.1" },
    "claim_effect": { "const": "descriptive_only" },
    "bundles": {
      "type": "array",
      "minItems": 2,
      "maxItems": 32,
      "items": { "$ref": "#/$defs/bundle" }
    }
  },
  "$defs": {
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "title",
        "kind",
        "description",
        "claims"
      ],
      "properties": {
        "bundle_id": {
          "type": "string",
          "pattern": "^https://github\\.com/0al-spec/agent-surface/conformance/bundles/[a-z0-9]+(?:-[a-z0-9]+)*/v1$"
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 128 },
        "kind": { "enum": ["foundation", "feature_overlay"] },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "claims": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "items": { "$ref": "#/$defs/claim" }
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "feature_ids",
        "requirement_ids",
        "vector_ids"
      ],
      "properties": {
        "profile_id": {
          "$ref": "https://github.com/0al-spec/agent-surface/conformance/schemas/suite/v1#/$defs/profileId"
        },
        "producer_role": { "enum": ["application", "runtime"] },
        "feature_ids": {
          "type": "array",
          "maxItems": 13,
          "uniqueItems": true,
          "items": {
            "$ref": "https://github.com/0al-spec/agent-surface/conformance/schemas/suite/v1#/$defs/featureId"
          }
        },
        "requirement_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "https://github.com/0al-spec/agent-surface/conformance/schemas/suite/v1#/$defs/requirementId"
          }
        },
        "vector_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "https://github.com/0al-spec/agent-surface/conformance/schemas/suite/v1#/$defs/vectorId"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "profile_id": {
                "const": "https://github.com/0al-spec/agent-surface/conformance/receipt-producer/v1"
              }
            }
          },
          "then": { "required": ["producer_role"] },
          "else": { "not": { "required": ["producer_role"] } }
        }
      ]
    }
  }
}
