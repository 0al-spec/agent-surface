{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0al-spec/agent-surface/conformance/schemas/observation/v1",
  "title": "ASP Sanitized Conformance Observation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "subject_sha256",
    "harness_sha256",
    "counterpart_sha256s",
    "observation_id",
    "vector_id",
    "step_id",
    "tokens",
    "state_deltas",
    "captured_at",
    "sanitization"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string",
      "pattern": "^urn:uuid:[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "subject_sha256": {
      "$ref": "#/$defs/digest"
    },
    "harness_sha256": {
      "$ref": "#/$defs/digest"
    },
    "counterpart_sha256s": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/digest"
      }
    },
    "observation_id": {
      "type": "string",
      "pattern": "^obs-[A-Za-z0-9._:-]{1,128}$"
    },
    "vector_id": {
      "$ref": "#/$defs/vectorId"
    },
    "step_id": {
      "const": "final"
    },
    "tokens": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/observationToken"
      }
    },
    "asp_error": {
      "$ref": "#/$defs/aspError"
    },
    "policy_reason": {
      "enum": [
        "approval_denied",
        "approval_required",
        "approval_satisfied",
        "app_policy_denied",
        "binding_invalid",
        "limit_exceeded",
        "local_policy_denied",
        "policy_allowed",
        "resource_denied",
        "scope_denied"
      ]
    },
    "match_reason": {
      "const": "input_unknown"
    },
    "state_deltas": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/stateDelta"
      }
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "sanitization": {
      "const": "synthetic_or_redacted"
    },
    "evidence_sha256": {
      "$ref": "#/$defs/digest"
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha-256:[A-Za-z0-9_-]{42}[AEIMQUYcgkosw048]$"
    },
    "vectorId": {
      "type": "string",
      "pattern": "^ASP-V-(SP|GI|AE|RP|RM|AA)-[0-9]{3}$"
    },
    "aspError": {
      "enum": [
        "action_unknown",
        "execution_transition_invalid",
        "grant_missing",
        "grant_proof_invalid",
        "grant_revoked",
        "idempotency_conflict",
        "input_not_normalized",
        "input_unknown",
        "integrity_mismatch",
        "outcome_unknown",
        "passport_status_unavailable",
        "scope_denied",
        "surface_incompatible",
        "training_use_denied",
        "risk_denied",
        "runtime_untrusted",
        "rate_limited",
        "capacity_state_unavailable",
        "service_unavailable",
        "elicitation_invalid"
      ]
    },
    "observationToken": {
      "enum": [
        "action_accepted",
        "action_rejected",
        "adapter_request_rejected",
        "application_receipt_emitted",
        "approval_not_reopened",
        "child_grant_revoked",
        "control_event_emitted",
        "credential_invalidated",
        "credential_rejected",
        "current_state_checked",
        "denial_recorded",
        "grant_issued",
        "grant_rejected",
        "grant_revoked",
        "input_schema_checked",
        "execution_token_invalidated",
        "local_denial_recorded",
        "manifest_published",
        "manifest_rejected",
        "mediation_stopped",
        "normalization_checked",
        "original_result_replayed",
        "original_revocation_replayed",
        "proof_rejected",
        "proof_session_invalidated",
        "receipt_rejected",
        "receipt_verified",
        "reservation_invalidated",
        "revocation_confirmed",
        "revocation_fence_established",
        "runtime_receipt_emitted",
        "same_receipt_replayed",
        "tuple_checked",
        "typed_request_forwarded",
        "operational_limits_validated",
        "operational_limits_checked",
        "operational_admission_committed",
        "operational_capacity_rejected",
        "capacity_response_validated",
        "operational_state_retained",
        "operational_identity_reused",
        "event_first_delivery_admitted",
        "event_transmitted",
        "event_delivery_retransmitted",
        "event_identity_reused",
        "event_delivery_queued",
        "operational_planning_reserved",
        "retry_delay_floor_satisfied",
        "local_backoff_selected",
        "semantic_identity_reused",
        "per_attempt_authentication_applied",
        "retry_scheduled",
        "retry_suppressed",
        "retry_deferred",
        "authoritative_capacity_recovery_required",
        "authoritative_capacity_recovery_confirmed",
        "capacity_decision_required",
        "capacity_response_rejected",
        "outcome_reconciliation_required",
        "http_capacity_response_bound",
        "http_capacity_binding_validated",
        "http_capacity_binding_rejected",
        "http_status_mapped",
        "http_no_store_applied",
        "http_no_store_validated",
        "http_retry_after_bound",
        "http_retry_after_validated",
        "ahp_binding_validated",
        "ahp_binding_rejected",
        "asp_tuple_validated",
        "ahp_ui_state_presented",
        "ahp_ui_update_suppressed",
        "ahp_control_translated",
        "asp_authority_unchanged",
        "asp_authority_retained",
        "action_dispatch_suppressed",
        "credential_withheld",
        "elicitation_binding_validated",
        "elicitation_binding_rejected",
        "elicitation_request_presented",
        "elicitation_response_accepted",
        "elicitation_response_suppressed",
        "elicitation_choice_validated",
        "elicitation_candidate_revalidated",
        "elicitation_candidate_rejected",
        "elicitation_redline_applied",
        "elicitation_prior_authority_invalidated",
        "step_up_result_verified",
        "step_up_result_rejected",
        "human_secret_withheld",
        "elicitation_authority_unchanged",
        "elicitation_authority_retained",
        "risk_explanation_validated",
        "risk_explanation_rejected",
        "risk_explanation_selected",
        "risk_explanation_rendered_literal",
        "risk_explanation_binding_rejected",
        "risk_explanation_suppressed",
        "canonical_risk_presented",
        "canonical_effects_presented",
        "risk_explanation_authority_unchanged",
        "risk_explanation_used_as_authority",
        "canonical_risk_suppressed",
        "canonical_effects_suppressed",
        "agent_instruction_suppressed",
        "agent_instruction_projected"
      ]
    },
    "stateName": {
      "enum": [
        "action.dispatch_count",
        "action.effect_count",
        "adapter.fabricated_evidence_count",
        "adapter.forwarded_count",
        "approval.interaction_count",
        "budget.application_charge",
        "credential.issued_count",
        "credential.accepted_count",
        "credential.active_count",
        "credential.adapter_retained_count",
        "credential.agent_visible_count",
        "control_event.emitted_count",
        "execution_token.active_count",
        "grant.child_active_count",
        "grant.issued_count",
        "grant.lifecycle",
        "idempotency.record_count",
        "idempotency.record_version",
        "manifest.accepted_count",
        "receipt.application_count",
        "receipt.runtime_count",
        "proof_session.accepted_count",
        "proof_session.active_count",
        "reservation.active_count",
        "revocation.confirmed_count",
        "revocation.confirmed_after_effective",
        "revocation.effective_count",
        "revocation.fence_count",
        "runtime.credential_release_count",
        "runtime.remote_disclosure_count",
        "runtime.retry_count",
        "runtime.stored_grant_width",
        "runtime.training_dispatch_count",
        "surface.version_binding_count",
        "application.workload_count",
        "operational.action.window_count",
        "operational.action.secondary_window_count",
        "operational.action.slot_acquisition_count",
        "operational.action.in_flight_count",
        "operational.event.delivery_record_count",
        "operational.event.delivery_identity_count",
        "operational.event.first_delivery_count",
        "operational.event.in_flight_count",
        "operational.event.transmission_count",
        "operational.event.queued_count",
        "event.cursor_advance_count",
        "runtime.local_window_count",
        "runtime.local_in_flight_count",
        "runtime.semantic_idempotency_binding_count",
        "runtime.runaway_guard_epoch",
        "runtime.retry_delay_floor_seconds",
        "runtime.retry_wait_pending",
        "runtime.capacity_recovery_pending",
        "runtime.capacity_decision_pending",
        "runtime.ahp_representation_revision",
        "runtime.ahp_presentation_count",
        "runtime.elicitation_revision",
        "runtime.elicitation_response_count",
        "runtime.step_up_verified_count",
        "runtime.risk_explanation_presentation_count",
        "application.proposal_revision",
        "application.proposal_update_count"
      ]
    },
    "stateValue": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "string",
          "enum": [
            "absent",
            "active",
            "inactive",
            "present",
            "revoked",
            "unchanged"
          ]
        }
      ]
    },
    "stateDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "before",
        "after"
      ],
      "properties": {
        "state": {
          "$ref": "#/$defs/stateName"
        },
        "before": {
          "$ref": "#/$defs/stateValue"
        },
        "after": {
          "$ref": "#/$defs/stateValue"
        }
      }
    }
  }
}
