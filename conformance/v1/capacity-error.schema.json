{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0al-spec/agent-surface/conformance/schemas/capacity-error/v1",
  "title": "ASP Operational Capacity Error Envelope v1",
  "oneOf": [
    {
      "$ref": "#/$defs/rateLimited"
    },
    {
      "$ref": "#/$defs/capacityStateUnavailable"
    },
    {
      "$ref": "#/$defs/serviceUnavailable"
    }
  ],
  "$defs": {
    "positiveSafeInteger": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "limit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limit_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "retry_after_seconds": {
          "$ref": "#/$defs/positiveSafeInteger"
        }
      }
    },
    "rateLimited": {
      "type": "object",
      "required": [
        "code",
        "description",
        "retryable"
      ],
      "properties": {
        "code": {
          "const": "rate_limited"
        },
        "description": {
          "$ref": "#/$defs/description"
        },
        "retryable": {
          "type": "boolean"
        },
        "limit": {
          "$ref": "#/$defs/limit"
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "limit"
            ],
            "properties": {
              "limit": {
                "required": [
                  "retry_after_seconds"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "retryable": {
                "const": true
              }
            }
          }
        }
      ]
    },
    "capacityStateUnavailable": {
      "type": "object",
      "not": {
        "required": [
          "limit"
        ]
      },
      "required": [
        "code",
        "description",
        "retryable"
      ],
      "properties": {
        "code": {
          "const": "capacity_state_unavailable"
        },
        "description": {
          "$ref": "#/$defs/description"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "serviceUnavailable": {
      "type": "object",
      "not": {
        "required": [
          "limit"
        ]
      },
      "required": [
        "code",
        "description",
        "retryable"
      ],
      "properties": {
        "code": {
          "const": "service_unavailable"
        },
        "description": {
          "$ref": "#/$defs/description"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    }
  }
}
