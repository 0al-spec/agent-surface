{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0al-spec/agent-surface/tools/asp-replay/schemas/checks/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile", "version", "checks"],
  "properties": {
    "schema_version": { "const": 1 },
    "profile": {
      "const": "https://github.com/0al-spec/agent-surface/tools/asp-replay/checks/v1"
    },
    "version": { "const": "1.0.0" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "title"],
        "properties": {
          "check_id": {
            "type": "string",
            "pattern": "^ASP-REPLAY-[A-Z-]+-001(?![\\s\\S])"
          },
          "title": { "type": "string", "minLength": 1, "maxLength": 160 }
        }
      }
    }
  }
}
