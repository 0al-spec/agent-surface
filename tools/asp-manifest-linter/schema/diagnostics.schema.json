{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0al-spec/agent-surface/tools/asp-manifest-linter/diagnostics/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "tool", "input", "summary", "diagnostics"],
  "properties": {
    "$schema": {"const": "https://github.com/0al-spec/agent-surface/tools/asp-manifest-linter/diagnostics/v1"},
    "schema_version": {"const": 1},
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "ruleset_id", "ruleset_version"],
      "properties": {
        "name": {"const": "asp-manifest-linter"},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "ruleset_id": {"const": "https://github.com/0al-spec/agent-surface/tools/asp-manifest-linter/rules/v1"},
        "ruleset_version": {"const": "1.0.0"}
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {"source": {"type": "string", "minLength": 1}}
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["errors", "warnings"],
      "properties": {
        "errors": {"type": "integer", "minimum": 0},
        "warnings": {"type": "integer", "minimum": 0}
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {"$ref": "#/$defs/diagnostic"}
    }
  },
  "$defs": {
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "severity", "path", "message", "help"],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^ASP-LINT-[A-Z]+-[0-9]{3}$"
        },
        "severity": {"enum": ["error", "warning"]},
        "path": {"type": "string", "pattern": "^/"},
        "message": {"type": "string", "minLength": 1},
        "help": {"type": "string", "minLength": 1}
      }
    }
  }
}
