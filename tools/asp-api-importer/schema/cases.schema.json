{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0al-spec/agent-surface/tools/asp-api-importer/cases/v1",
  "type": "object",
  "required": ["schema_version", "profile", "linter_ruleset", "cases"],
  "properties": {
    "schema_version": {"const": 1},
    "profile": {
      "const": "https://github.com/0al-spec/agent-surface/profiles/api-import/v1"
    },
    "linter_ruleset": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": {
          "const": "https://github.com/0al-spec/agent-surface/tools/asp-manifest-linter/rules/v1"
        },
        "version": {
          "const": "1.1.0"
        }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["id", "source", "expect", "golden"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "source": {"type": "string", "minLength": 1},
              "expect": {"const": "success"},
              "golden": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["id", "source", "expect", "error_contains"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "source": {"type": "string", "minLength": 1},
              "expect": {"const": "failure"},
              "error_contains": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
